const dialogBusinessUnitOptions: ComboboxOption[] = [
  { value: "TAS", label: "TAS" },
  { value: "RO", label: "RO" },
  { value: "LPG", label: "LPG" },
];

const alertSectionOptions: ComboboxOption[] = [
  { value: "VA", label: "VA" },
  { value: "VTS", label: "VTS" },
  { value: "TAS", label: "TAS" },
  { value: "LPG", label: "LPG" },
  { value: "RO", label: "RO" },
];

const assigneeOptions: ComboboxOption[] = [
  { value: "NovexSupport", label: "NovexSupport" },
  { value: "TechSupport", label: "TechSupport" },
];

const ticketStateOptions: ComboboxOption[] = [
  { value: "ToDo", label: "To Do" },
  { value: "InProgress", label: "In Progress" },
  { value: "Resolved", label: "Resolved" },
