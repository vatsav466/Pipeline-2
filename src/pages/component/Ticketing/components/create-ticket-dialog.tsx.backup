        </CardFooter>
      </Card>
    )}

    <div className="mt-2">
      <span className="w-28 text-sm font-medium">Reporter</span>
      <Input
        value={reporter}
        onChange={(e) => setReporter(e.target.value)}
        placeholder="Enter Reporter Name"
        className="h-8 text-xs"
      />
    </div>
    
    <div className="mt-5">
      <FormField label="Ticket State" required>
        <ReusableCombobox
          options={ticketStateOptions}
          value={dialogTicketState}
          onValueChange={(val) =>
            setDialogTicketState(val as Ticket["ticket_state"])
          }
          placeholder="Select State"
          buttonClassName="h-8"
          disabled={formElementsDisabled}
        />
      </FormField>
    </div>
    
    <div className="mt-3">
