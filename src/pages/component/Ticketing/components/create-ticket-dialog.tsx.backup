                                                    <Plus className="h-4 w-4" />
                                                </span>
                                            </Link>
                                        )}
                                    </div>
      </FormField>
    </div>
  </SectionWrapper>

          {/* Block Vehicle Button - Only show for tickets created from VTS Live, Risk Score, or VTS section in SOD terminal dashboard */}
