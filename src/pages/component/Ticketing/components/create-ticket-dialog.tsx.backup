            <div className="mt-4">
              <Button
                type="button"
                variant="outline"
                size="sm"
                className="w-full h-10 text-sm bg-red-600 hover:bg-red-700 text-white hover:text-white shadow-lg border-2 border-red-500 hover:border-red-600 font-semibold transition-all duration-200"
                disabled={formElementsDisabled || isBlockingVehicle}
                onClick={handleBlockVehicle}
              >
                {isBlockingVehicle ? (
                  <Loader2 className="h-5 w-5 animate-spin" />
                ) : null}
{isBlockingVehicle ? (
                  <span className="font-medium">Blocking...</span>
                ) : (
                  <>
                    <Ban className="h-5 w-5 mr-2" />
                    <span className="font-medium">Block Vehicle</span>
                    {/* <Truck className="h-5 w-5 ml-2" /> */}
                  </>
                )}
              </Button>
            </div>
          )}
          </div>

          {/* Subtask IDs Section */}
          {isEditMode &&
            subtaskIds &&
            Array.isArray(subtaskIds) &&
            subtaskIds.length > 0 &&
            subtaskIds.some((id) => id && id.trim() !== "") && (
              <div className="mb-4">
                <SectionWrapper title="Subtask IDs">
                  <div className="col-span-full">
                    <div className="border rounded-lg overflow-hidden">
                      <div className="overflow-x-auto max-h-96 overflow-y-auto">
                        <table className="w-full border-collapse text-xs">
                          <thead className="bg-gray-50 sticky top-0">
                            <tr className="border-b">
                              <th className="text-left py-2 px-3 font-semibold text-gray-700">
                                Subtask ID
                              </th>
                            </tr>
                          </thead>
                          <tbody>
                            {subtaskIds
                              .filter((id) => id && id.trim() !== "")
